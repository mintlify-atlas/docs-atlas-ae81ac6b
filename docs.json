{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ZBar",
  "theme": "aspen",
  "colors": {
    "primary": "#dc0a7d",
    "light": "#0d8381",
    "dark": "#a0a193"
  },
  "favicon": "https://media.brand.dev/dde8b460-4a25-4202-84c9-7d85cc385beb.png",
  "logo": {
    "light": "https://media.brand.dev/dde8b460-4a25-4202-84c9-7d85cc385beb.png",
    "dark": "https://media.brand.dev/dde8b460-4a25-4202-84c9-7d85cc385beb.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/mchehab/zbar"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mchehab/zbar"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/scanning-images",
              "guides/video-scanning",
              "guides/integration",
              "guides/configuration"
            ]
          },
          {
            "group": "Language Bindings",
            "pages": [
              "bindings/c-cpp",
              "bindings/python",
              "bindings/perl",
              "bindings/java"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/overview",
              "api/image-scanner",
              "api/processor",
              "api/decoder",
              "api/symbols"
            ]
          },
          {
            "group": "Video & Display",
            "pages": [
              "api/video",
              "api/window"
            ]
          },
          {
            "group": "GUI Widgets",
            "pages": [
              "api/gtk-widget",
              "api/qt-widget"
            ]
          }
        ]
      },
      {
